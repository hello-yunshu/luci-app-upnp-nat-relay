{
	"luci-app-upnp-bridge-relay": {
		"description": "Grant access to UPnP Bridge Relay",
		"read": {
			"ubus": {
				"upnp_bridge_relay": [ "status", "refresh-env", "check-env", "check-network", "network-cache", "dry-run", "openclash-rule-cache", "read-log", "version" ]
			},
			"uci": [ "upnp_bridge_relay" ],
			"file": [ "/tmp/upnp_bridge_relay/*" ]
		},
		"write": {
			"ubus": {
				"upnp_bridge_relay": [ "sync-now", "clear", "clear-log", "start", "stop", "restart", "setup-interface", "fix-zone", "generate-openclash-rule", "setup-openclash", "restart-openclash", "remove-openclash-rule", "rollback" ],
				"luci": [ "setInitAction" ]
			},
			"uci": [ "upnp_bridge_relay" ]
		}
	}
}
