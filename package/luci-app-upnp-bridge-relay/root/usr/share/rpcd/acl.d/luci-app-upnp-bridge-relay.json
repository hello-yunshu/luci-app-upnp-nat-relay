{
	"luci-app-upnp-bridge-relay": {
		"description": "Grant access to UPnP Bridge Relay",
		"read": {
			"ubus": {
				"upnp_bridge_relay": [ "status", "check-env", "check-network", "dry-run", "read-log" ]
			},
			"uci": [ "upnp_bridge_relay" ],
			"file": [ "/tmp/upnp_bridge_relay/*" ]
		},
		"write": {
			"ubus": {
				"upnp_bridge_relay": [ "sync-now", "clear", "setup-interface", "fix-zone", "setup-openclash", "remove-openclash-rule", "rollback" ],
				"luci": [ "setInitAction" ]
			},
			"uci": [ "upnp_bridge_relay" ]
		}
	}
}
