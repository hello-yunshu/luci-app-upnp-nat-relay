#!/bin/sh

[ -f /lib/functions.sh ] && . /lib/functions.sh

RPCD_VERSION="@PKG_VERSION@"
UPNP_BRIDGE_RELAY_BIN="/usr/bin/upnp-bridge-relay"
STATUS_FILE="/tmp/upnp_bridge_relay/status.json"
INIT_SCRIPT="/etc/init.d/upnp_bridge_relay"

service_action() {
	action="$1"

	case "$action" in
		start|restart)
			uci set upnp_bridge_relay.main.enabled='1' 2>/dev/null
			uci commit upnp_bridge_relay 2>/dev/null
			"$INIT_SCRIPT" enable >/dev/null 2>&1
			;;
		stop)
			uci set upnp_bridge_relay.main.enabled='0' 2>/dev/null
			uci commit upnp_bridge_relay 2>/dev/null
			;;
	esac

	case "$action" in
		start)
			"$INIT_SCRIPT" start >/dev/null 2>&1
			;;
		stop)
			"$INIT_SCRIPT" stop >/dev/null 2>&1
			;;
		restart)
			"$INIT_SCRIPT" restart >/dev/null 2>&1
			;;
		*)
			echo '{"success":false,"error":"unknown_action"}'
			return 0
			;;
	esac

	_rc=$?
	if [ "$_rc" -ne 0 ]; then
		printf '{"success":false,"action":"%s","error":"init_action_failed","rc":%d}\n' "$action" "$_rc"
		return 0
	fi

	_wait=0
	while [ "$_wait" -lt 4 ]; do
		if [ "$action" = "stop" ]; then
			if ! "$INIT_SCRIPT" status >/dev/null 2>&1; then
				printf '{"success":true,"action":"%s","running":false}\n' "$action"
				return 0
			fi
		else
			if "$INIT_SCRIPT" status >/dev/null 2>&1; then
				printf '{"success":true,"action":"%s","running":true}\n' "$action"
				return 0
			fi
		fi
		sleep 1
		_wait=$((_wait + 1))
	done

	if [ "$action" = "stop" ]; then
		printf '{"success":false,"action":"%s","error":"service_still_running"}\n' "$action"
	else
		printf '{"success":false,"action":"%s","error":"service_not_running"}\n' "$action"
	fi
}

case "$1" in
	list)
		cat <<'EOF'
{
	"status": {},
	"refresh-env": {},
	"check-env": {},
	"check-network": {},
	"network-cache": {},
	"dry-run": {},
	"generate-openclash-rule": {},
	"openclash-rule-cache": {},
	"read-log": {},
	"clear-log": {},
	"sync-now": {},
	"clear": {},
	"start": {},
	"stop": {},
	"restart": {},
	"setup-interface": {},
	"fix-zone": {},
	"setup-openclash": {},
	"remove-openclash-rule": {},
	"rollback": {},
	"version": {}
}
EOF
		;;
	call)
		method="$2"
		case "$method" in
			status)
				"$UPNP_BRIDGE_RELAY_BIN" --status 2>/dev/null || echo '{"running":false,"last_sync":"","last_result":"unknown","backend":"","read_count":0,"accepted_count":0,"rejected_count":0,"failure_count":0,"accepted":[],"rejected":[],"last_error":"Status file not found"}'
				;;
			refresh-env)
				"$UPNP_BRIDGE_RELAY_BIN" --refresh-env 2>/dev/null || echo '{"nft_table_status":"-","openclash_status":"-","version":"-","openwrt_version":"","package_manager":"unknown","firewall":"unknown","fw4":0,"nft":0,"upnpc":0,"luci":0,"openclash_installed":0,"openclash_running":0,"openclash_has_access_control":0,"updated_at":""}'
				;;
			check-env)
				"$UPNP_BRIDGE_RELAY_BIN" --check-env 2>/dev/null || echo '{"error":"check-env failed"}'
				;;
			check-network)
				"$UPNP_BRIDGE_RELAY_BIN" --check-network 2>/dev/null || echo '{"error":"check-network failed"}'
				;;
			network-cache)
				"$UPNP_BRIDGE_RELAY_BIN" --network-cache 2>/dev/null || echo '{"cached":0,"updated_at":""}'
				;;
			dry-run)
				"$UPNP_BRIDGE_RELAY_BIN" --dry-run 2>/dev/null || echo '{"error":"dry-run failed"}'
				;;
			generate-openclash-rule)
				"$UPNP_BRIDGE_RELAY_BIN" --generate-openclash-rule 2>/dev/null || echo '{"error":"generate-openclash-rule failed"}'
				;;
			openclash-rule-cache)
				"$UPNP_BRIDGE_RELAY_BIN" --openclash-rule-cache 2>/dev/null || echo '{"cached":false,"updated_at":"","openclash_suggestion":{}}'
				;;
			read-log)
				"$UPNP_BRIDGE_RELAY_BIN" --read-log 2>/dev/null || echo '{"success":false,"error":"read-log failed","logs":""}'
				;;
			clear-log)
				"$UPNP_BRIDGE_RELAY_BIN" --clear-log 2>/dev/null || echo '{"success":false,"error":"clear-log failed"}'
				;;
			sync-now)
				"$UPNP_BRIDGE_RELAY_BIN" --sync 2>/dev/null || echo '{"success":false,"error":"sync_failed"}'
				;;
			clear)
				"$UPNP_BRIDGE_RELAY_BIN" --clear 2>/dev/null
				;;
			start)
				service_action start
				;;
			stop)
				service_action stop
				;;
			restart)
				service_action restart
				;;
			setup-interface)
				"$UPNP_BRIDGE_RELAY_BIN" --setup-interface 2>/dev/null
				;;
			fix-zone)
				"$UPNP_BRIDGE_RELAY_BIN" --fix-zone 2>/dev/null
				;;
			setup-openclash)
				"$UPNP_BRIDGE_RELAY_BIN" --setup-openclash 2>/dev/null
				;;
			remove-openclash-rule)
				"$UPNP_BRIDGE_RELAY_BIN" --remove-openclash-rule 2>/dev/null
				;;
			rollback)
				"$UPNP_BRIDGE_RELAY_BIN" --rollback 2>/dev/null
				;;
			version)
				printf '{"version":"%s"}\n' "$RPCD_VERSION"
				;;
			*)
				echo '{"error":"unknown_method"}'
				;;
		esac
		;;
	*)
		echo '{"error":"invalid_usage"}'
		;;
esac
