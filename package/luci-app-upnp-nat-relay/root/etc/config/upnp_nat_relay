config service 'main'
	option enabled '0'
	option interval '60'
	option backend 'upnpc'

	option bind_ifname 'eth2'
	option bind_ip '192.168.3.50'
	option downstream_lan_gateway '192.168.3.1'
	option downstream_lan_subnet '192.168.3.0/24'
	option downstream_wan_ip '192.168.2.2'
	option upstream_wan_if 'pppoe-wan'

	option show_advanced_config '0'
	option auto_config_network '0'
	option auto_config_firewall_zone '0'
	option firewall_zone_name 'upnp_nat'

	option allowed_external_ports '40000-65535'
	option protocols 'tcp udp'
	option failure_grace_count '3'
	option clear_on_stop '1'
	option dry_run '0'
	option log_level 'info'
	option deny_low_ports '1'
	option restrict_to_subnet '1'
	option deny_empty_description '0'
	option log_rejected '1'

	option openclash_mode 'prompt'
	option openclash_return_strategy 'per_mapping'
	option openclash_backup '1'
	option openclash_rule_remark 'UPnP NAT Relay Auto RETURN'
	option openclash_auto_restart '0'
	option openclash_sync_interval '0'

config deny_ports 'default'
	list port '22'
	list port '23'
	list port '25'
	list port '53'
	list port '80'
	list port '110'
	list port '143'
	list port '443'
	list port '445'
	list port '465'
	list port '587'
	list port '993'
	list port '995'
	list port '1433'
	list port '3306'
	list port '3389'
	list port '5432'
	list port '6379'
	list port '8080'
	list port '8443'

config backend 'upnpc'
	option enabled '1'
	option command 'upnpc'
	option timeout '10'

config backend 'custom'
	option enabled '0'
	option command ''
	option output_format 'json'
