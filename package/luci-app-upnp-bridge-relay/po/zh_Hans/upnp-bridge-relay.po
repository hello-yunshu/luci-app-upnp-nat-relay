msgstr "自动检测失败："

msgid "The network interface connected to the downstream router LAN side, used only for reading UPnP mappings."
msgstr "连接到下游路由器 LAN 侧的网络接口，仅用于读取 UPnP 映射。"

msgid "IP address on the read interface. Must be on the same subnet as the downstream router LAN."
msgstr "读取接口上的 IP 地址。需与下游路由器 LAN 在同一子网。"

msgid "The LAN-side gateway IP address of the downstream router."
msgstr "下游路由器的 LAN 侧网关地址。"

msgid "Downstream router LAN subnet in CIDR format, used for source filtering."
msgstr "下游路由器 LAN 子网（CIDR 格式），用于来源过滤。"

msgid "Downstream router WAN IP address, used as the DNAT rule target."
msgstr "下游路由器 WAN IP 地址，用作 DNAT 规则目标。"

msgid "The upstream WAN interface where DNAT rules will be created."
msgstr "上游 WAN 接口，DNAT 规则将在此接口上创建。"

msgid "Port range allowed for synchronization. Using 1-65535 is NOT recommended as it effectively creates a DMZ."
msgstr "允许同步的端口范围。不建议使用 1-65535，因为实际上等同于创建 DMZ。"

msgid "Control how OpenClash transparent proxy affects forwarded ports. \"Off\" ignores OpenClash, \"Prompt\" shows suggested rules, \"Auto\" writes rules automatically."
msgstr "控制 OpenClash 透明代理如何影响转发端口。「关闭」忽略 OpenClash，「提示」显示建议规则，「自动」自动写入规则。"

msgid "Please select an interface."
msgstr "请选择接口。"

msgid "Bind IP is required."
msgstr "绑定 IP 为必填项。"

msgid "Downstream LAN Gateway is required."
msgstr "下游 LAN 网关为必填项。"

msgid "Downstream LAN Subnet is required."
msgstr "下游 LAN 子网为必填项。"

msgid "Invalid subnet format. Please use CIDR notation (e.g. 192.168.3.0/24)."
msgstr "子网格式无效。请使用 CIDR 格式（如 192.168.3.0/24）。"

msgid "Downstream WAN IP is required."
msgstr "下游 WAN IP 为必填项。"

msgid "Please select an upstream WAN interface."
msgstr "请选择上游 WAN 接口。"

msgid "Allowed external ports is required."
msgstr "允许的外部端口为必填项。"

msgid "%s is required."
msgstr "%s 为必填项。"

msgid "Invalid Bind IP address format."
msgstr "绑定 IP 地址格式无效。"

msgid "Invalid subnet format."
msgstr "子网格式无效。"

msgid "e.g. 192.168.3.50"
msgstr "如 192.168.3.50"

msgid "e.g. 192.168.3.1"
msgstr "如 192.168.3.1"

msgid "e.g. 192.168.3.0/24"
msgstr "如 192.168.3.0/24"

msgid "e.g. 192.168.2.2"
msgstr "如 192.168.2.2"

msgid "e.g. 40000-65535"
msgstr "如 40000-65535"

